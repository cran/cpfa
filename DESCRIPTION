Package: cpfa
Type: Package
Title: Classification with Parallel Factor Analysis
Version: 1.3.0
Date: 2026-06-02
Authors@R: person(given = c("Matthew", "A."), family = "Asisgress", 
                  email = "mattgress@protonmail.ch", role = c("aut", "cre"), 
                  comment = c(ORCID = "0000-0001-7294-3348"))
